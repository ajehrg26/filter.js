(function _showSnake() {
  const _old = document.getElementById('__ar_snake__');
  if (_old) _old.remove();

  const _snake = document.createElement('div');
  _snake.id = '__ar_snake__';
  _snake.textContent = '🐍';
  _snake.style.cssText = [
    'position:fixed',
